pass
  where
    src/tiles/*.h

  what
    tile <<name>> {
      texture = <<texture>>;
      durability = <<durability>>;
    }

  init
    count = 0
    enum = []
    hits = []
    textures = []

  instance
    enum += <<name>> = <<count++>>,
    textures += <<texture>>,
    hits += 
      case <<name>>: {
        << "return false;" if durability == "0" else "return true;" >>
      } break;

  out server
    enum tile {
      <<enum>>
    }

    bool hit_tile(tile t) {
      switch(t) {
        <<hits>>
        default: return false;
      }
    }

  out client
    tile_texture tile_textures[] = {
      <<textures>>
    }
